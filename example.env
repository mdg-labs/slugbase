# SlugBase Environment Configuration
# Copy this file to .env and update the values as needed

# ============================================
# Server Configuration
# ============================================
# Port for the backend server
PORT=5000

# Environment: 'development' or 'production'
NODE_ENV=development

# Base URL of the application (used for OIDC callbacks)
# In production, set this to your domain (e.g., https://slugbase.example.com)
BASE_URL=http://localhost:5000

# Frontend URL (for CORS and redirects)
# In production, set this to your frontend domain (e.g., https://slugbase.example.com)
FRONTEND_URL=http://localhost:3000

# ============================================
# JWT Configuration
# ============================================
# Secret key for JWT token signing
# IMPORTANT: Change this to a random, secure string in production!
# You can generate one with: openssl rand -base64 32
# This is used to sign and verify JWT tokens for authentication
JWT_SECRET=slugbase-jwt-secret-change-in-production

# JWT token expiration time (default: 7d)
# Examples: '1h', '7d', '30d', '1y'
JWT_EXPIRES_IN=7d


# ============================================
# Encryption Configuration
# ============================================
# Encryption key for sensitive data (OIDC secrets, etc.)
# IMPORTANT: Generate a secure 64-character hex key for production!
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or use: openssl rand -hex 32
# This key must be kept secret and backed up securely!
ENCRYPTION_KEY=

# ============================================
# Database Configuration
# ============================================
# Database type: 'sqlite' or 'postgresql'
DB_TYPE=sqlite

# SQLite Configuration (used when DB_TYPE=sqlite)
# Path to the SQLite database file
DB_PATH=./data/slugbase.db

# PostgreSQL Configuration (used when DB_TYPE=postgresql)
# Option A: Connection string (e.g. Neon) - postgresql://user:pass@host/db?sslmode=require
# DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
# Option B: Individual params - uncomment and configure these if using PostgreSQL:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=slugbase
# DB_USER=postgres
# DB_PASSWORD=your-postgres-password

# ============================================
# Contact Form Configuration
# ============================================
# Email address to receive contact form submissions (optional)
# SELFHOSTED: Requires SMTP configured in Admin Settings
# CLOUD: Requires Postmark configured (see CLOUD section below)
# CONTACT_FORM_RECIPIENT=contact@example.com

# ============================================
# CLOUD MODE - Postmark (when SLUGBASE_MODE=cloud)
# ============================================
# Transactional email via Postmark API. Get token from https://account.postmarkapp.com
# The From address must be verified in your Postmark server
# POSTMARK_SERVER_API_TOKEN=your-postmark-server-api-token
# POSTMARK_FROM=noreply@slugbase.app
# POSTMARK_FROM_NAME=SlugBase

# ============================================
# CLOUD MODE - Stripe (when SLUGBASE_MODE=cloud)
# ============================================
# Billing via Stripe. Use test keys (pk_test_*, sk_test_*, whsec_*) for staging/sandbox.
# See docs/internal/stripe-setup.md for setup guide.
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_PERSONAL_MONTHLY=price_xxx
# STRIPE_PRICE_PERSONAL_YEARLY=price_xxx
# STRIPE_PRICE_TEAM_MONTHLY=price_xxx
# STRIPE_PRICE_TEAM_YEARLY=price_xxx
# STRIPE_PRICE_EARLY_SUPPORTER=price_xxx

# Frontend build env (for Stripe publishable key):
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ============================================
# Stats Endpoint (optional, for Grafana / monitoring)
# ============================================
# When set, GET /api/admin/stats returns system metrics. Requires X-Stats-Secret header.
# Generate with: openssl rand -hex 32
# STATS_ENDPOINT_SECRET=

# ============================================
# Sentry Error Tracking (optional)
# ============================================
# When set, errors are reported to Sentry. Omit to disable (no network calls).
# Backend: SENTRY_DSN from https://sentry.io project settings
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production

# Frontend build-time (for source map upload):
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# VITE_SENTRY_ENVIRONMENT=production

# CI/CD source map upload (optional):
# SENTRY_AUTH_TOKEN=your-auth-token
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

# GitHub secrets for frontend Sentry (passed as build args during deploy):
# SENTRY_DSN_STAGING - DSN from your frontend Sentry project (staging)
# SENTRY_DSN_PROD - DSN from your frontend Sentry project (production)

# Sentry debug/testing (omit in production):
# Backend: enables GET /api/debug-sentry which throws a test error
# SENTRY_DEBUG=true
# Frontend build-time: shows floating test buttons in the UI
# VITE_SENTRY_DEBUG=true

# ============================================
# AI Suggestions (CLOUD mode only)
# ============================================
# OpenAI API key for AI bookmark suggestions. Required for AI in Cloud mode.
# AI_OPENAI_API_KEY=sk-...
# Optional: model override (default: gpt-4o-mini)
# AI_OPENAI_MODEL=gpt-4o-mini

# ============================================
# OIDC Provider Configuration
# ============================================
# OIDC providers are configured through the admin interface
# or via the API (/api/oidc-providers endpoints).
# Client secrets are automatically encrypted in the database.
# The configuration is stored in the database.
