{
  "name": "slugbase",
  "version": "1.0.0",
  "description": "Self-hosted bookmark manager with optional link forwarding",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "packages/core",
    "apps/selfhosted"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "build": "npm run build --workspace=backend && node scripts/copy-core-dist.js && npm run build --workspace=frontend && node scripts/copy-selfhosted-public.js",
    "start": "npm run start --workspace=slugbase-selfhosted",
    "publish:core": "node scripts/publish-core.js",
    "publish:core:dry-run": "node scripts/publish-core.js --dry-run",
    "e2e": "playwright test --config=e2e/playwright.config.ts",
    "e2e:run": "node scripts/run-e2e.js",
    "e2e:ui": "playwright test --ui --config=e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@bigbinary/neeto-playwright-reporter": "^3.0.0-beta.7",
    "@playwright/test": "^1.49.0",
    "concurrently": "^8.2.2"
  },
  "overrides": {
    "qs": "6.14.2",
    "esbuild": "^0.25.0",
    "minimatch": "10.2.1",
    "glob": "10.5.0"
  }
}
