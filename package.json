{
  "name": "slugbase",
  "version": "1.0.0",
  "description": "Self-hosted bookmark manager with optional link forwarding",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "packages/core",
    "apps/selfhosted"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "build": "npm run build --workspace=backend && node scripts/copy-core-dist.js && npm run build --workspace=frontend && npm run build:core-embed --workspace=frontend && node scripts/sync-core-locales.js && node scripts/copy-selfhosted-public.js",
    "start": "npm run start --workspace=slugbase-selfhosted",
    "assemble:core": "node scripts/assemble-core-package.js",
    "assemble:core:no-build": "node scripts/assemble-core-package.js --no-build",
    "pack:cloud": "node scripts/pack-core-for-cloud.mjs",
    "e2e": "playwright test --config=e2e/playwright.config.ts",
    "e2e:docker": "bash e2e/docker/run-e2e-docker.sh",
    "e2e:run": "node scripts/run-e2e.js",
    "e2e:ui": "playwright test --ui --config=e2e/playwright.config.ts",
    "tolgee:pull": "tolgee pull",
    "tolgee:push": "tolgee push"
  },
  "devDependencies": {
    "@bigbinary/neeto-playwright-reporter": "^3.0.0-beta.7",
    "@playwright/test": "^1.49.0",
    "@tolgee/cli": "^2.16.1",
    "concurrently": "^8.2.2"
  },
  "overrides": {
    "qs": "6.14.2",
    "esbuild": "^0.25.0",
    "minimatch": "10.2.3",
    "glob": "10.5.0",
    "brace-expansion": "5.0.5",
    "yaml": "2.8.3",
    "path-to-regexp": "0.1.13",
    "lodash": "^4.17.24"
  }
}
