# Dependencies
node_modules/

# Build outputs (do not commit; npm publish must include packages/core/backend/dist via build+pack script or CI)
dist/
build/
*.tsbuildinfo

# Apps/selfhosted copied frontend (generated by scripts/copy-selfhosted-public.js)
apps/selfhosted/public/

# Tolgee CLI local overrides (API keys, etc.)
.tolgeerc.local

# Environment and secrets (keep .env.example as template)
.env
.env.local
.env.*.local
staging.env
prod.env
.env.sentry-build-plugin

# Logs and debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS and IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# Database files
*.db
*.db-journal

# Data directory
data/
backend/data/

# Docker Compose - use docker-compose.example.yml as template
docker-compose.yml

# Pack/publish artifacts (do not commit)
*.tgz
.publish-core/

# Core npm package build outputs (assembled by scripts/assemble-core-package.js)
packages/core/frontend/publish/
packages/core/frontend/src/
packages/core/backend/dist/

