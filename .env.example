# SlugBase Core (self-hosted) environment configuration
# Copy this file to .env and update values for your deployment.

# ============================================================
# Core Runtime
# ============================================================
NODE_ENV=development
PORT=5000
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5000

# Optional comma-separated additional CORS origins.
# Example: CORS_EXTRA_ORIGINS=https://admin.example.com,https://tools.example.com
# CORS_EXTRA_ORIGINS=

# Optional: disable new user registrations by setting to false.
REGISTRATIONS_ENABLED=true

# ============================================================
# Security (required)
# ============================================================
# Required. Must be >= 32 chars in production.
JWT_SECRET=replace-with-a-secure-random-string

# Optional JWT TTL (default 7d in runtime).
JWT_EXPIRES_IN=7d

# Required in production (recommended in all environments).
# Should be >= 32 chars.
SESSION_SECRET=replace-with-another-secure-random-string

# Required. Used to encrypt sensitive config (OIDC secrets, SMTP creds, etc.).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-char-hex

# Optional. Issuer name shown in authenticator apps for TOTP MFA (otpauth URI).
# If unset or empty, defaults to "SlugBase". Set to your product name for white-label or cloud.
# MFA_ISSUER_NAME=SlugBase

# ============================================================
# Database
# ============================================================
# Supported: sqlite, postgresql
DB_TYPE=sqlite

# SQLite
DB_PATH=./data/slugbase.db

# PostgreSQL (choose either DATABASE_URL or individual params)
# DATABASE_URL=postgresql://user:password@localhost:5432/slugbase
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=slugbase
# DB_USER=postgres
# DB_PASSWORD=postgres

# ============================================================
# Optional Integrations
# ============================================================
# Contact form recipient for /api/contact endpoint.
# SMTP transport itself is configured via Admin Settings in-app.
# CONTACT_FORM_RECIPIENT=contact@example.com

# Protect /api/admin/stats with X-Stats-Secret header.
# STATS_ENDPOINT_SECRET=

# ============================================================
# Optional Sentry
# ============================================================
# Backend runtime
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production
# SENTRY_DEBUG=false

# Frontend build-time
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_DEBUG=false

# Optional: allow Umami (or other analytics on this origin) past Content-Security-Policy.
# Server runtime only. Use the tracker origin, e.g. https://umami.example.com (or full script URL — origin is used).
# CSP_UMAMI_ORIGIN=https://umami.example.com

# Optional: Bugsink / self-hosted Sentry-compatible ingest for browser error POST (Content-Security-Policy connect-src).
# CSP_BUGSINK_ORIGIN=https://bugsink.example.com

# Optional release metadata for health endpoint
# COMMIT_SHA=local

# ============================================================
# Tolgee (optional — in-context translation editing in dev)
# ============================================================
# Self-hosted Tolgee: https://tolgee.mdg-labs.dev (project id 3 in .tolgeerc)
# VITE_TOLGEE_API_URL=https://tolgee.mdg-labs.dev
# VITE_TOLGEE_API_KEY=
# For tolgee pull / push: set TOLGEE_API_KEY in the shell or .env.local (gitignored).

# ============================================================
# Notes
# ============================================================
# - OIDC providers are configured via Admin UI/API and stored in DB.
# - AI suggestions provider key/model are configured in system settings (DB), not env.
