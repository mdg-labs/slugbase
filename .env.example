# SlugBase Environment Variables
# Copy this file to .env and update with your values

# ============================================
# REQUIRED - Security Variables
# ============================================
# Generate these with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or use: openssl rand -hex 32

# JWT Secret - Used for signing JWT tokens (REQUIRED)
# Must be at least 32 characters
JWT_SECRET=your-jwt-secret-here-minimum-32-characters-long

# Encryption Key - Used for encrypting sensitive data like SMTP passwords (REQUIRED)
# Must be at least 32 characters (64 hex characters recommended)
ENCRYPTION_KEY=your-encryption-key-here-minimum-32-characters-long

# ============================================
# OPTIONAL - Application Configuration
# ============================================

# Running mode: selfhosted (default) or cloud (SaaS)
# SELFHOSTED: current behavior; OIDC from admin; single JWT cookie.
# CLOUD: fixed Google/Microsoft/GitHub from env; short-lived JWT + refresh token; marketing pages.
SLUGBASE_MODE=selfhosted

# Node Environment
# Options: development, production
NODE_ENV=production

# Server Port (default: 5000)
PORT=5000

# Frontend URL - Used for CORS and redirects (recommended in production)
# Example: http://localhost:3000 (development) or https://app.slugbase.app (CLOUD)
FRONTEND_URL=http://localhost:3000

# Base URL - Used for OIDC callbacks and API documentation (recommended in production)
# Example: http://localhost:5000 (development) or https://api.slugbase.app (CLOUD)
BASE_URL=http://localhost:5000

# Session Secret - Used for OIDC OAuth flow session signing (REQUIRED in production, min 32 chars)
SESSION_SECRET=change-this-secret-in-production

# Contact Form - Email address to receive contact form submissions (optional)
# When set, form submissions are forwarded to this address. Requires SMTP to be configured.
# CONTACT_FORM_RECIPIENT=contact@example.com

# JWT Expiration - How long JWT tokens are valid (default: 7d, SELFHOSTED only)
# Examples: 1h, 24h, 7d, 30d
JWT_EXPIRES_IN=7d

# ============================================
# CLOUD MODE ONLY (when SLUGBASE_MODE=cloud)
# ============================================
# For Docker: set SLUGBASE_MODE=cloud (and VITE_API_URL if API is on another host), then
# rebuild the image so the frontend shows the landing page, pricing, and contact at /.
# COOKIE_DOMAIN=.slugbase.app
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7
# CORS_EXTRA_ORIGINS=https://slugbase.app
# OIDC_GOOGLE_CLIENT_ID=
# OIDC_GOOGLE_CLIENT_SECRET=
# OIDC_MICROSOFT_CLIENT_ID=
# OIDC_MICROSOFT_CLIENT_SECRET=
# OIDC_MICROSOFT_TENANT=common
# OIDC_GITHUB_CLIENT_ID=
# OIDC_GITHUB_CLIENT_SECRET=
# SMTP (CLOUD: from env; SELFHOSTED: from Admin Settings)
SMTP_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=SlugBase

# ============================================
# OPTIONAL - Database Configuration
# ============================================

# Database Type
# Options: sqlite, postgresql
# Default: sqlite
DB_TYPE=postgresql

# SQLite Database Path (only used if DB_TYPE=sqlite)
# Default: ./data/slugbase.db
# DB_PATH=./data/slugbase.db

# PostgreSQL Configuration (only used if DB_TYPE=postgresql)
# Option A: Connection string (e.g. for Neon) - postgresql://user:pass@host/db?sslmode=require
# DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
# Option B: Individual params (e.g. for Cloud SQL, local PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=slugbase
DB_USER=slugbase
DB_PASSWORD=your-postgres-password

# ============================================
# NOTES
# ============================================
# - Never commit the .env file to version control
# - Generate strong secrets for JWT_SECRET and ENCRYPTION_KEY
# - In production, use HTTPS and set FRONTEND_URL and BASE_URL to your actual domains
# - For Docker, DB_PATH should be set to /app/data/slugbase.db (handled automatically in docker-compose.yml)
